{
  "name": "@kunlunxu/wf",
  "version": "0.1.1",
  "private": true,
  "packageManager": "pnpm@10.0.0",
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter @kunlunxu/wf-examples dev",
    "build": "pnpm build:packages",
    "build:packages": "turbo run build --filter=./packages/*",
    "build:examples": "pnpm --filter @kunlunxu/wf-examples build",
    "start": "pnpm --filter @kunlunxu/wf-examples start",
    "lint": "pnpm --filter @kunlunxu/wf-examples lint",
    "prepare": "husky",
    "cz": "czg",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm build:packages && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.7",
    "@commitlint/cli": "^20.0.0",
    "@commitlint/config-conventional": "^20.0.0",
    "@eslint/eslintrc": "^3.3.1",
    "@next/eslint-plugin-next": "^15.5.4",
    "@tailwindcss/postcss": "^4.1.13",
    "@types/lodash-es": "^4.17.12",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^24",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "czg": "^1.12.0",
    "eslint": "^9.36.0",
    "eslint-config-next": "^15.5.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^5.2.0",
    "esbuild-sass-plugin": "^3.3.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.1",
    "postcss": "^8",
    "prettier": "^3.6.2",
    "prettier-plugin-tailwindcss": "^0.6.14",
    "sass": "^1.93.2",
    "stylelint": "^16.24.0",
    "stylelint-config-standard-scss": "^16.0.0",
    "tailwindcss": "^4.1.13",
    "tsup": "^8.5.0",
    "turbo": "^2.5.8",
    "typescript": "^5.9.2"
  }
}
